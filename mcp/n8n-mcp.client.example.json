{
  "mcpServers": {
    "n8n-render": {
      "command": "python",
      "args": [
        "orchestrator/mcp/n8n_mcp_server.py"
      ],
      "env": {
        "N8N_BASE_URL": "https://your-n8n-service.onrender.com",
        "N8N_API_KEY": "replace-with-real-api-key",
        "N8N_HTTP_TIMEOUT": "30",
        "N8N_MCP_ENABLE_WRITE": "false"
      }
    }
  }
}
