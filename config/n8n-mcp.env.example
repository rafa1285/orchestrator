# n8n target (Render public URL)
N8N_BASE_URL=https://your-n8n-service.onrender.com

# Create in n8n: Settings -> n8n API -> Create API key
N8N_API_KEY=replace-with-real-api-key

# HTTP timeout in seconds for n8n API calls
N8N_HTTP_TIMEOUT=30

# Multiagent backend public URL (for run status tools)
MULTIAGENT_API_BASE_URL=https://your-multiagent-api.onrender.com

# Safety switch: keep false by default for read-only mode
# Set true to allow: n8n_set_workflow_active, n8n_trigger_webhook
N8N_MCP_ENABLE_WRITE=false
